{
  "name": "claude-kanban",
  "version": "1.0.0",
  "description": "A local kanban board for managing Claude Code projects with MCP integration",
  "type": "module",
  "bin": {
    "claude-kanban": "./dist/cli.js",
    "claude-kanban-mcp": "./dist/mcp.js"
  },
  "main": "./dist/server.js",
  "exports": {
    ".": "./dist/server.js",
    "./mcp": "./dist/mcp.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "node scripts/build.js",
    "build:cli": "tsup src/index.ts --format esm --out-dir dist --clean --entry.cli=src/index.ts",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "claude",
    "kanban",
    "mcp",
    "claude-code",
    "task-management",
    "ai-assistant"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": ""
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "better-sqlite3": "^11.0.0",
    "commander": "^12.0.0",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "nanoid": "^5.0.4"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.8",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.0",
    "tsup": "^8.0.1",
    "typescript": "^5.3.3"
  }
}
