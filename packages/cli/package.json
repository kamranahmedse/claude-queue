{
  "name": "claude-queue",
  "version": "1.0.4",
  "description": "A local kanban board for managing Claude Code projects",
  "type": "module",
  "bin": {
    "claude-queue": "./dist/cli.js",
    "claude-queue-mcp": "./dist/mcp.js"
  },
  "main": "./dist/server.js",
  "exports": {
    ".": "./dist/server.js",
    "./mcp": "./dist/mcp.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsx scripts/build.ts",
    "build:cli": "tsup src/index.ts --format esm --out-dir dist --clean --entry.cli=src/index.ts",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "claude",
    "kanban",
    "mcp",
    "claude-code",
    "task-management",
    "ai-assistant"
  ],
  "author": "Kamran Ahmed <kamranahmed.se@gmail.com>",
  "license": "MIT",
  "homepage": "https://github.com/kamranahmedse/claude-queue#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kamranahmedse/claude-queue.git"
  },
  "bugs": {
    "url": "https://github.com/kamranahmedse/claude-queue/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.25.2",
    "better-sqlite3": "^12.5.0",
    "commander": "^14.0.2",
    "cors": "^2.8.5",
    "express": "^5.2.1",
    "http-proxy-middleware": "^3.0.5",
    "nanoid": "^5.1.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.0.3",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
