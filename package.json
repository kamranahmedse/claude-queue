{
  "name": "claude-kanban",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -n server,ui -c blue,green \"pnpm dev:server\" \"pnpm dev:ui\"",
    "dev:server": "pnpm --filter @claude-kanban/server dev",
    "dev:ui": "pnpm --filter @claude-kanban/ui dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "start": "node packages/server/dist/index.js"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "typescript": "^5.3.3"
  }
}
