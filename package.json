{
  "name": "claude-queue",
  "description": "Create a task queue for claude code to work autonomously.",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "PORT=3334 concurrently -n server,ui -c blue,green \"pnpm dev:server\" \"pnpm dev:ui\"",
    "dev:server": "PORT=3334 pnpm --filter @claude-queue/server dev",
    "dev:ui": "PORT=3334 pnpm --filter @claude-queue/ui dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "start": "node packages/server/dist/index.js"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "prettier": "^3.7.4",
    "typescript": "^5.9.3"
  }
}
